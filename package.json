{
  "name": "weave",
  "version": "0.0.1",
  "description": "NL-commanded todo app running a finetuned 26M-param model in-browser (WebGPU/TS) — a tiny-model generative-UI proof of concept",
  "private": true,
  "license": "MIT",
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "analyze": "cross-env ANALYZE=true next build",
    "deploy": "next build && cd out && vercel link --yes --project weave && vercel deploy --prod",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.3",
    "@hugeicons/react": "^1.1.6",
    "@json-render/core": "^0.19.0",
    "@json-render/react": "^0.19.0",
    "@json-render/shadcn": "^0.19.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^19.0.0",
    "@next/bundle-analyzer": "16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@webgpu/types": "^0.1.71",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "simple-git-hooks": "^2.11.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver",
    "simple-git-hooks"
  ]
}
