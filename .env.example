# Environment variables for this project.
# Copy this file to .env.local (gitignored) and fill in real values.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only.
#
# Used by metadataBase, robots.ts, and sitemap.ts. Set to your production
# origin (no trailing slash) when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Examples (uncomment + edit as needed):
# DATABASE_URL=
