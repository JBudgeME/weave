# Force LF line endings on all text files so Windows/Mac don't fight.
* text=auto eol=lf

# Binary files — never normalize.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.avif   binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.pdf    binary

# Lockfile — keep as LF text so diffs are clean.
bun.lock text eol=lf
